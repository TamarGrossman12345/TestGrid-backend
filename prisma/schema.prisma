datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id          String   @id @default(uuid())
  projectName String
  description String?
  isPrivate   Boolean    @default(false)
  files       TestFile[]
}

model TestFile {
  id        String     @id @default(uuid())
  name      String
projectId String
  project   Project    @relation(fields: [projectId], references: [id])
  testCases TestCase[] 
}

model TestCase {
  id              String    @id @default(uuid())
  title           String
  testSteps       String
  expectedResults String    
  status          String
  fileId          String
  testFile        TestFile @relation(fields: [fileId], references: [id])
}