datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

model Project {
  projectId   String     @id @default(uuid())
  projectName String
  description String?
  isPrivate   Boolean    @default(false)
  files       TestFile[]
}

model TestFile {
  TestFileId  String     @id @default(uuid())
  name        String
  description String?
  projectId   String
  project     Project    @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  testCases   TestCase[]
}


model TestCase {
  TestCaseId      String   @id @default(uuid())
  serialId         Int?      @unique 
  title           String
  testSteps       String
  expectedResults String
  status          String
  fileId          String
  testFile        TestFile @relation(fields: [fileId], references: [TestFileId], onDelete: Cascade)
}