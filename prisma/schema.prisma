datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

enum Role {
  QA
  DEVELOPER
  TEAM_LEAD
  SECTION_LEAD
}

enum TeamName {
  PRISMA
  NEW_SPACE
  NEXT
  NEXSOS
  PLANING
  PANORAMA
  SDA
}

model User {
  userId  String     @id @default(uuid())
  username String   @unique
  password  String
  team     TeamName
  role  Role     @default(QA)
}

model Project {
  projectId   String     @id @default(uuid())
  projectName String
  description String?
  isPrivate   Boolean    @default(false)
  files       TestFile[]
  team  TeamName 
}

model TestFile {
  TestFileId  String     @id @default(uuid())
  name        String
  description String?
  projectId   String
  project     Project    @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  testCases   TestCase[]
}


model TestCase {
  TestCaseId      String   @id @default(uuid())
  serialId         Int?      @unique 
  title           String
  testSteps       String
  expectedResults String
  status          String
  fileId          String
  testFile        TestFile @relation(fields: [fileId], references: [TestFileId], onDelete: Cascade)
}